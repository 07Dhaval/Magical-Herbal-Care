# Optional override: set to `live` or `test` to force a mode.
# Otherwise preview/development prefers test keys and production prefers live keys.
RAZORPAY_ENV=
RAZORPAY_KEY_ID=your_razorpay_live_key_id
RAZORPAY_KEY_SECRET=your_razorpay_live_key_secret
RAZORPAY_TEST_KEY_ID=your_razorpay_test_key_id
RAZORPAY_TEST_KEY_SECRET=your_razorpay_test_key_secret
ALLOWED_ORIGINS=http://localhost:5173,https://magical-herbal-care.vercel.app
